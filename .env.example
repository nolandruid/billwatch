# BillWatch environment variables.
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local` — only this example file is tracked.

# --- Supabase (Project Settings → API) ---
# Public, safe to expose to the browser:
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# Server-only. Bypasses Row Level Security — NEVER expose to the client:
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- Email delivery (Resend: https://resend.com) ---
RESEND_API_KEY="re_your_api_key"
# Verified sender address on your domain (SPF/DKIM/DMARC configured):
EMAIL_FROM="BillWatch <notify@billwatch.ca>"

# --- Cron protection ---
# Random secret; the sync/notify cron routes require this in an Authorization header.
# Generate with: openssl rand -hex 32
CRON_SECRET="generate-a-long-random-string"

# --- Feedback ---
# Discord webhook URL. SERVER-ONLY — used by /api/feedback, never sent to the browser.
DISCORD_FEEDBACK_WEBHOOK_URL="https://discord.com/api/webhooks/xxx/yyy"

# --- App ---
# Public base URL, used to build confirm/unsubscribe links in emails.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
